# Root .env.example
# This file contains default environment variables for the uptime monitor

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Database Configuration
# Type: sqlite or postgresql
DB_TYPE=sqlite
DB_PATH=./data/uptime.db

# PostgreSQL Configuration (when DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uptime_monitor
DB_USER=uptime
DB_PASSWORD=password

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-key-replace-this-in-production

# API Configuration
API_KEY_REQUIRED=false
ENABLE_REGISTRATION=true

# Email Configuration for Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@uptimemonitor.com

# Telegram Configuration for Alerts
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Webhook Configuration
WEBHOOK_TIMEOUT=5000

# Monitoring Configuration
MONITORING_INTERVAL=10000
MAX_RESPONSE_TIME=30000

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3001/api
